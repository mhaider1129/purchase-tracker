# Example (non-secret) env file for local setup
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB
JWT_SECRET=changeme
PORT=5000
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Purchase Tracker" <your-email@example.com>
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://wici-procurement.org,https://www.wici-procurement.org

# Supabase shared attachment storage (recommended for multi-server / multi-device access)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=attachments
SUPABASE_STORAGE_PREFIX=attachments

# Set to false in production to avoid silently storing files on local disk when Supabase upload fails.
ATTACHMENT_LOCAL_FALLBACK_ENABLED=false